# Exécution
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
TRUST_PROXY=false

# PostgreSQL — exemple réservé au développement local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/domotoculture

# Sessions et comptes
SESSION_SECRET=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
PUBLIC_REGISTRATION_ENABLED=false
ADMIN_EMAIL=admin@domotoculture.fr
ADMIN_INITIAL_PASSWORD=CHANGE_ME_WITH_AT_LEAST_12_CHARACTERS

# Stripe Checkout — utiliser uniquement des clés de test localement
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudinary — facultatif tant que les images sont saisies par URL persistante
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email — facultatif
EMAIL_PROVIDER=console
EMAIL_FROM=contact@domotoculture.fr
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
